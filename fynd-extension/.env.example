# --- Fynd Partner Panel credentials (required) ---
# Get these from console.fynd.com → Extensions → your extension → Credentials
EXTENSION_API_KEY=your_api_key_here
EXTENSION_API_SECRET=your_api_secret_here

# --- Public URL of THIS extension service (required) ---
# Must match what you set as "Extension URL" in the Fynd Partner panel.
# On Render this will be e.g. https://cottonworld-fynd-extension.onrender.com
EXTENSION_BASE_URL=https://cottonworld-fynd-extension.onrender.com

# --- Fynd cluster (prod default) ---
FP_API_DOMAIN=https://api.fynd.com

# --- Streamlit app to iframe (defaults to the existing Render deployment) ---
STREAMLIT_URL=https://cottonworld-fynd-automation.onrender.com/

# --- Optional ---
PORT=8080
SQLITE_PATH=/tmp/session_storage.db
